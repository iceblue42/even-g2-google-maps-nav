{
  "package_id": "com.evennav.googlemaps",
  "edition": "202601",
  "name": "EvenNav",
  "version": "1.0.4",
  "min_app_version": "0.0.1",
  "min_sdk_version": "0.0.9",
  "entrypoint": "index.html",
  "supported_languages": ["en"],
  "permissions": [
    {
      "name": "network",
      "desc": "Access Google Maps APIs for navigation and map tiles",
      "whitelist": [
        "maps.googleapis.com",
        "www.googleapis.com",
        "basemaps.cartocdn.com",
        "airquality.googleapis.com",
        "weather.googleapis.com",
        "pollen.googleapis.com",
        "ipapi.co"
      ]
    },
    {
      "name": "location",
      "desc": "Track position for navigation"
    }
  ]
}
